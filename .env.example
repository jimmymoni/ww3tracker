# Replicate API Token (CHEAPER than Kimi!)
# Get from: https://replicate.com/account/api-tokens
# Costs ~$0.0001-0.0002 per analysis (100x cheaper than Kimi)
REPLICATE_API_TOKEN=your_replicate_token_here

# Giphy API Key (optional - for Trump GIFs)
# Get from: https://developers.giphy.com/
GIPHY_API_KEY=your_giphy_api_key_here

# NASA FIRMS API Key (optional - for satellite fire data)
# Register free at: https://firms.modaps.eosdis.nasa.gov/
NASA_FIRMS_KEY=your_nasa_firms_key_here

# ============================================
# NEWS API CONFIGURATION
# ============================================
# GNews API (Recommended - 100 requests/day free)
# Get from: https://gnews.io/register
NEWS_API_KEY=your_gnews_api_key_here

# Alternative: NewsAPI.org (100 requests/day free)
# NEWSAPI_KEY=your_newsapi_key_here

# Server Port
PORT=3001

# ============================================
# EMAIL ALERT SERVICE CONFIGURATION
# ============================================
# SMTP Provider Settings (Gmail, SendGrid, AWS SES, etc.)

# Option 1: Gmail SMTP
# Generate App Password: https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_gmail_app_password
SMTP_FROM=alerts@ww3tracker.live

# Option 2: SendGrid SMTP (Recommended - 100 emails/day free)
# Get API Key: https://app.sendgrid.com/settings/api_keys
# SMTP_HOST=smtp.sendgrid.net
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=apikey
# SMTP_PASS=your_sendgrid_api_key
# SMTP_FROM=alerts@ww3tracker.live

# Option 3: AWS SES
# SMTP_HOST=email-smtp.us-east-1.amazonaws.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your_ses_username
# SMTP_PASS=your_ses_password
# SMTP_FROM=alerts@ww3tracker.live

# Email Batching Interval (milliseconds, default: 1 hour)
# EMAIL_BATCH_INTERVAL=3600000

# ============================================
# AUTO-PUBLISHER CONFIGURATION
# ============================================
# Telegram Bot Token (for admin notifications)
# Get from @BotFather: https://t.me/botfather
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Twitter/X API (for tweet scheduling)
# TWITTER_API_KEY=your_key
# TWITTER_API_SECRET=your_secret
# TWITTER_ACCESS_TOKEN=your_token
# TWITTER_ACCESS_SECRET=your_secret
