# Replicate API Token (CHEAPER than Kimi!)
# Get from: https://replicate.com/account/api-tokens
# Costs ~$0.0001-0.0002 per analysis (100x cheaper than Kimi)
REPLICATE_API_TOKEN=your_replicate_token_here

# Giphy API Key (optional - for Trump GIFs)
# Get from: https://developers.giphy.com/
GIPHY_API_KEY=your_giphy_api_key_here

# NASA FIRMS API Key (optional - for satellite fire data)
# Register free at: https://firms.modaps.eosdis.nasa.gov/
NASA_FIRMS_KEY=your_nasa_firms_key_here

# Server Port
PORT=3001
